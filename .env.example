M365_TENANT_ID=your-tenant-id-guid
M365_CLIENT_ID=your-public-client-app-id
# Optional but recommended for cross-user mailbox review and app-only auth.
# M365_CLIENT_SECRET=your-app-client-secret
# Optional: default admin UPN to use for login selection and silent token reuse.
# M365_USERNAME=admin@yourtenant.onmicrosoft.com
# Optional: set this to bypass device-code auth with a pre-acquired Graph token.
# M365_ACCESS_TOKEN=
# Optional: override the cache path used for MSAL token storage.
# M365_TOKEN_CACHE_PATH=~/.config/m365-admin-tool/token-cache.json
# Optional: define multiple tenant profiles in ./tenants.json or ~/.config/m365-admin-tool/tenants.json
